{
  "expo": {
    "name": "Deone Conductor",
    "slug": "deone-conductor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCgmH-sn4SOZ8ujKoJMuLImFsFvtzXFpWA"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ],
      "package": "com.deone.conductor"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Deone Conductor necesita tu ubicación para mostrarte a los clientes cercanos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Deone Conductor necesita acceso a tus fotos para subir documentos.",
          "cameraPermission": "Deone Conductor necesita acceso a la cámara para fotografiar documentos."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FFC400",
          "defaultChannel": "solicitudes",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "43e6f4b6-10f2-4b14-8aa5-a033e3697bd3"
      }
    }
  }
}
